# ==============================================================================
# Module 02 — Workflow Orchestration (Kestra) + Postgres (NYC Taxi)
# .env.example
# ==============================================================================
# Copy to `.env`:
#   cp .env.example .env
#
# Notes
# - DB_PORT is the *host* port mapping only (laptop -> container:5432).
# - Containers (Kestra tasks + utility container) must connect to Postgres via:
#     ENV_DB_HOST:ENV_DB_PORT  (default: pgdatabase:5432)
# ==============================================================================


# ==============================================================================
# 1) Target Postgres (NY Taxi warehouse) — service: pgdatabase
# ==============================================================================
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ny_taxi
DB_SCHEMA=public
# Host mapping: localhost:${DB_PORT} -> pgdatabase:5432
DB_PORT=5433


# ==============================================================================
# 2) Kestra internal Postgres (metadata) — service: kestra_postgres
# ==============================================================================
KESTRA_POSTGRES_USER=kestra
KESTRA_POSTGRES_PASSWORD=kestra
KESTRA_POSTGRES_DB=kestra


# ==============================================================================
# 3) Kestra UI login (basicAuth) — service: kestra
# ==============================================================================
KESTRA_ADMIN_EMAIL=admin@admin.com
KESTRA_ADMIN_PASSWORD=Admin1234


# ==============================================================================
# 4) Optional tools (compose profile: tools) — pgAdmin
# ==============================================================================
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=Admin1234
PGADMIN_PORT=8085


# ==============================================================================
# 5) Runtime variables (used by Kestra flows + utility container)
# ==============================================================================
# Container-to-container DB connection (NOT localhost, NOT DB_PORT)
ENV_DB_HOST=pgdatabase
ENV_DB_PORT=5432
ENV_DB_USER=postgres
ENV_DB_PASSWORD=postgres
ENV_DB_NAME=ny_taxi
ENV_DB_SCHEMA=public

# Kestra Docker task runner network (must match the actual Compose network name)
# Usually: dtc-module-02_dtc-net
ENV_DOCKER_NETWORK=dtc-module-02_dtc-net

# Ingestion image (built in Module 01)
ENV_INGEST_IMAGE=ingestion_pipeline:v1.0.1


# ==============================================================================
# 6) Optional ingestion defaults (ported from Module 01)
#    Flows may override these at runtime.
# ==============================================================================
TAXI=green
YEAR=2021
MONTH=01

FILE_FORMAT=csv
IF_EXISTS=replace
KEEP_LOCAL=false

# Optional: used by ingest-url mode (leave empty unless needed)
DATA_URL=

# Loader tuning
LOADER_CHUNK_SIZE=50000
LOADER_BATCH_SIZE=100000

# Logging / UX
LOG_LEVEL=INFO
ENABLE_PROGRESS=false
