# ==============================================================================
# NYC Taxi Ingestion Pipeline — .env.example
#
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# Notes:
# - main.py loads `.env` with override=False
#   -> real environment variables (Docker/Kestra/CI) will win.
# - Do NOT commit `.env` (secrets).
# ==============================================================================


# ==============================================================================
# 1) Database connection (used by main.py -> build_pg_client())
#
# Host machine (psql/DBeaver):
#   DB_HOST=localhost
#   DB_PORT=<exposed port> (default 5432)
#
# Docker Compose:
# - app service overrides DB_HOST=db and DB_PORT=5432 internally
# - db service exposes ${DB_PORT}:5432 to host
# ==============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ny_taxi
DB_SCHEMA=public


# ==============================================================================
# 2) CLI defaults (Click options default from env)
# ==============================================================================
# Standard monthly ingest
TAXI=yellow
YEAR=2024
MONTH=01

# Source file format for URL builder: parquet | csv
FILE_FORMAT=parquet

# Strategy when destination table exists:
# - skip    : do nothing
# - fail    : exit with code 2
# - replace : staging -> atomic swap -> final
# - append  : staging -> validate -> INSERT -> final -> drop staging
IF_EXISTS=replace

# Keep downloaded file in DATA_DIR after processing
KEEP_LOCAL=true

# Custom URL ingest (used by `ingest-url`)
# DATA_URL=https://example.com/path/to/file.parquet


# ==============================================================================
# 3) Loader tuning (docker_ingestion_pipeline/config.py)
# ==============================================================================
# Rows per read chunk from source file (streaming)
LOADER_CHUNK_SIZE=50000

# Rows per internal batch flush into DB (COPY)
LOADER_BATCH_SIZE=10000


# ==============================================================================
# 4) Logging / UX (docker_ingestion_pipeline/config.py)
# ==============================================================================
# Console log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Enable tqdm progress bar rendering
ENABLE_PROGRESS=true


# ==============================================================================
# 5) Optional paths (docker_ingestion_pipeline/config.py)
# ==============================================================================
# Override default data directory (default: <project_root>/data)
# - For Docker Compose in this repo, app sets: DATA_DIR=/app/data
# - On host, you can keep it as ./data
# DATA_DIR=./data


# ==============================================================================
# 6) Optional tools (docker-compose profile: tools) — pgAdmin
# ==============================================================================
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=8085
