# -----------------------------------------------------------------------------
# Module 03 - Data Warehouse (GCS + BigQuery)
# Setup: cp .env.example .env  &&  fill the values
# -----------------------------------------------------------------------------

# === [GCP CORE CONFIGURATION] ===
# Required
GCP_PROJECT_ID=your-gcp-project-id

# BigQuery location (multi-region recommended for this homework)
BQ_LOCATION=US


# === [AUTHENTICATION] ===
# Leave empty if you use Application Default Credentials:
#   gcloud auth application-default login
# If you use a Service Account JSON, put the absolute path here.
GOOGLE_APPLICATION_CREDENTIALS=


# === [STORAGE (GCS) - RAW PARQUET LANDING] ===
# Bucket name must be globally unique
GCS_BUCKET_NAME=dtc-de-2026-ny-taxi-raw-yourname

# Folder prefix in bucket (no leading/trailing slash is recommended)
GCS_RAW_PREFIX=raw/ny_taxi

# Taxi dataset params (used by downloader + SQL templating)
TAXI_COLOR=yellow
TAXI_YEAR=2024

# Months to process (Jan-Jun 2024)
MONTHS=01,02,03,04,05,06

# Optional override: where to download from
# Default in code: https://d37ci6vzurychx.cloudfront.net/trip-data
TAXI_BASE_URL=


# === [BIGQUERY LAYERS (DATASETS)] ===
BQ_DATASET_STAGING=staging
BQ_DATASET_FINAL=final


# === [BIGQUERY TABLES] ===
# External table (reads parquet directly from GCS)
BQ_TABLE_EXT=ny_taxi_yellow_trip_2024_ext

# Materialized base table (BigQuery native storage, no partition/cluster)
BQ_TABLE_BASE=ny_taxi_yellow_trip_2024_base

# Final optimized table (partition + cluster)
BQ_TABLE_FINAL=ny_taxi_yellow_trip_2024


# === [SQL RUNNER SETTINGS] ===
# Directory containing *.sql scripts (relative to project root)
SQL_DIR=sql

# If you want to run a single SQL file by default, set it here (optional)
# Example: sql/01_create_external_table.sql
SQL_FILE=

# Default mode for SQL runner (true = dry-run / estimate bytes, false = execute)
BQ_DRY_RUN=true


# === [RUNTIME / LOGGING] ===
LOG_DIR=./apps/logs


# === [LOCAL WORKDIR] ===
# Optional: for local scratch/debugging (only used if your code reads it)
LOCAL_DATA_DIR=./data
