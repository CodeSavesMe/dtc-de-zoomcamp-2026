# -----------------------------------------------------------------------------
# Module 03 - Data Warehouse (GCS + BigQuery)
# Instructions: Copy this file to .env and fill in your actual values.
# -----------------------------------------------------------------------------

# --- Core GCP Settings ---
GCP_PROJECT_ID=your-project-id-here
BQ_LOCATION=US

# --- Auth (Leave empty if using local gcloud auth/ADC) ---
GOOGLE_APPLICATION_CREDENTIALS=

# --- GCS Source Configuration ---
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_RAW_PREFIX=
GCS_TLC_URI_PREFIX=

# --- Taxi Data Settings (yellow | green | fhv) ---
TAXI_COLOR=yellow
TAXI_YEAR=2021
MONTHS=01,02,03,04,05,06,07,08,09,10,11,12
TAXI_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data

# --- BigQuery Dataset Layers ---
BQ_DATASET_STAGING=trips_data_all
BQ_DATASET_FINAL=dbt_marts

# --- Table Naming ---
BQ_TABLE_EXT=yellow_tripdata_ext
BQ_TABLE_BASE=yellow_tripdata_base
BQ_TABLE_FINAL=yellow_tripdata

# --- SQL Runner Settings ---
SQL_DIR=sql
SQL_FILE=
SQL_PRINT_RESULTS=true
SQL_PRINT_MAX_ROWS=20
BQ_DRY_RUN=true

# --- Runtime & Performance Tuning ---
LOG_DIR=./logs
MAX_WORKERS=4
MAX_RETRIES=3
HTTP_TIMEOUT_SEC=300
GCS_CHUNK_SIZE=8388608