# -----------------------------------------------------------------------------
# Module 03 - Data Warehouse (GCS + BigQuery)
# Setup: cp .env.example .env  &&  fill the values
# -----------------------------------------------------------------------------

# --- GCP Core ---
GCP_PROJECT_ID="YOUR_GCP_PROJECT_ID"
BQ_LOCATION="US"

# Optional: only needed if you use a service account key file locally
# Example: /Users/you/.gcp/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=""

# --- GCS ---
GCS_BUCKET_NAME="03_dw_ny_taxi"
GCS_BUCKET_URL="gs://03_dw_ny_taxi"
GCS_RAW_PREFIX="raw/ny_taxi"

# --- Dataset scope ---
TAXI_COLOR="yellow"
TAXI_YEAR="2024"
MONTHS="01,02,03,04,05,06"
TAXI_BASE_URL="https://d37ci6vzurychx.cloudfront.net/trip-data"

# --- BigQuery ---
BQ_DATASET_STAGING="staging"
BQ_DATASET_FINAL="final"
BQ_TABLE_EXT="ny_taxi_yellow_trip_2024_ext"
BQ_TABLE_BASE="ny_taxi_yellow_trip_2024_base"
BQ_TABLE_FINAL="ny_taxi_yellow_trip_2024"

# --- SQL Runner ---
SQL_DIR="sql"
SQL_FILE=""
BQ_DRY_RUN="true"

# --- Local runtime ---
LOG_DIR="./logs"
LOCAL_DATA_DIR="./data"
